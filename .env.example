# Polymarket CLOB API
POLYMARKET_PRIVATE_KEY=0x...your_ethereum_private_key...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Odds Data (The Odds API - https://the-odds-api.com)
ODDS_API_KEY=

# Bankroll and risk limits (calibrated for $500 test)
BANKROLL_USDC=500
MAX_POSITION_USDC=25
MAX_TOTAL_EXPOSURE_USDC=300
MIN_EDGE_PCT=3.0
MAX_EDGE_PCT=200.0
KELLY_FRACTION=0.25

# Entry price range
MIN_ENTRY_PRICE=0.03
MAX_ENTRY_PRICE=0.50

# Scan interval (seconds)
SCAN_INTERVAL=300

# Learning agent
LEARNING_ENABLED=true
MIN_LEARNING_SAMPLES=20

# Merge arbitrage
MERGE_ENABLED=true
MIN_MERGE_PROFIT=0.02
